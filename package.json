{
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@happy-dom/global-registrator": "^20.8.4",
    "@types/bun": "^1.3.10",
    "eslint": "^9.39.4",
    "execa": "^9.6.1",
    "globals": "^17.4.0",
    "happy-dom": "^20.8.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "ora": "^9.3.0",
    "picocolors": "^1.1.1",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  },
  "lint-staged": {
    "*.{json,md,css,scss,less,html,vue,yaml,toml}": [
      "bun prettier --write"
    ],
    "*.{ts,tsx,js,jsx}": [
      "bun eslint --fix",
      "bun prettier --write"
    ]
  },
  "name": "bd-box",
  "private": true,
  "scripts": {
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "lint": "eslint . --fix",
    "plugin:install": "claude plugin install bd-dev@bd-plugins && claude plugin install bd@bd-plugins",
    "plugin:link-rules": "cp -r plugins/bd-dev/rules/* ~/.claude/rules/",
    "prepare": "husky",
    "test": "AGENT=1 bun run --parallel --workspaces test",
    "test:color": "cd packages/bd-color && bun test",
    "test:diagram": "cd packages/vscode-md-diagram && bun test",
    "test:lunar": "cd packages/bd-lunar && bun test",
    "test:token-previewer": "cd packages/bd-antd-token-previewer && bun test",
    "typecheck": "tsc --noEmit"
  },
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "shell-quote": "^1.8.3"
  }
}
