{
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.10",
    "eslint": "^10.0.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "execa": "^9.6.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "mint": "^4.2.423",
    "ora": "^9.3.0",
    "picocolors": "^1.1.1",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  },
  "lint-staged": {
    "*.{json,md,css,scss,less,html,vue,yaml,toml}": [
      "bun prettier --write"
    ],
    "*.{ts,tsx,js,jsx}": [
      "bun eslint --fix",
      "bun prettier --write"
    ]
  },
  "name": "bd-box",
  "private": true,
  "scripts": {
    "docs:dev": "mint dev",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "lint": "eslint . --fix",
    "plugin:install": "claude plugin install bd-dev@bd-plugins && claude plugin install bd@bd-plugins",
    "plugin:link-rules": "cp -r plugins/bd-dev/rules/* ~/.claude/rules/",
    "prepare": "husky",
    "test": "AGENT=1 bun run --parallel --workspaces --if-present test",
    "test:color": "cd packages/bd-color && bun test",
    "test:diagram": "cd packages/vscode-md-diagram && bun test",
    "test:lunar": "cd packages/bd-lunar && bun test",
    "test:token-previewer": "cd packages/bd-antd-token-previewer && bun test",
    "typecheck": "tsc --noEmit"
  },
  "workspaces": [
    "packages/*"
  ]
}
