{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "'${CLAUDE_PLUGIN_ROOT}/hooks/session-start.cmd'",
            "async": false
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "commit",
        "hooks": [
          {
            "type": "command",
            "command": "'${CLAUDE_PLUGIN_ROOT}/hooks/pre-commit.cmd'",
            "async": false
          }
        ]
      }
    ]
  }
}
