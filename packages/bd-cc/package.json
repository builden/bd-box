  "homepage": "https://cloudcli.ai",
  "keywords": [
    "claude code",
    "ai",
    "anthropic",
    "ui",
    "mobile"
  ],
  "license": "GPL-3.0",
  "lint-staged": {
    "src/**/*.{ts,tsx,js,jsx}": "eslint"
  },
  "main": "server/index.ts",
  "name": "@siteboon/claude-code-ui",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/siteboon/claudecodeui.git"
  },
  "scripts": {
    "build": "vite build",
    "cleanup": "bash scripts/cleanup-ports.sh",
    "client": "vite --host",
    "dev": "concurrently --kill-others \"bun run server\" \"bun run client\"",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "postinstall": "node scripts/fix-node-pty.js",
    "prepare": "husky",
    "prepublishOnly": "bun run build",
    "preview": "vite preview",
    "release": "bunx release-it",
    "release:patch": "bunx release-it patch",
    "release:minor": "bunx release-it minor",
    "release:major": "bunx release-it major",
    "server": "bun run server/index.ts",
    "start": "bun run build && bun run server",
    "test": "bun test",
    "test:unit": "bun test tests/unit/server/",
    "test:api": "bun test ./tests/api/*.api.ts",
    "test:coverage": "bun test --coverage",
    "test:e2e": "playwright test tests/e2e/",
    "test:e2e:ui": "playwright test tests/e2e/ --ui",
    "test:smoke": "playwright test tests/e2e/ --test-match \"*.smoke.e2e.ts\" --ui",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "type": "module",
  "version": "1.25.0"
}
